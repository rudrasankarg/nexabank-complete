# NexaBank Server — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or .env — only .env.example is safe to commit.

# ── PostgreSQL superuser (used only by db-setup.js) ──────────────────────────
# Your local 'postgres' superuser password
POSTGRES_SUPERUSER_PASSWORD=your_postgres_superuser_password_here
DB_SUPERUSER=postgres

# ── App database connection ───────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexabank_db
DB_USER=nexabank_user
DB_PASSWORD=your_nexabank_user_password_here
# DB_SSL=false

# For production (overrides individual vars above if set)
# DATABASE_URL=postgresql://nexabank_user:password@host:5432/nexabank_db

# ── JWT / Auth ────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
